# PumpPortal (WebSocket - no auth required)
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# DexPaprika (no auth required)
DEXPAPRIKA_API_BASE=https://api.dexpaprika.com

# DexScreener (no auth required)
DEXSCREENER_API_BASE=https://api.dexscreener.com

# Chainstack RPC
CHAINSTACK_API_KEY=your_chainstack_key_here
CHAINSTACK_RPC_URL=https://solana-mainnet.core.chainstack.com

# Shyft APIs
SHYFT_API_KEY=your_shyft_key_here
SHYFT_API_BASE=https://api.shyft.to

# Test Configuration
TEST_MINT_COUNT=30
TEST_TIMEOUT_MS=60000
VERBOSE_LOGGING=true
